#!/bin/sh
# Pre-commit hook: format and lint Go files in v2/.
# Install via: make install-hooks
set -e

ROOT=$(git rev-parse --show-toplevel)
cd "$ROOT/v2"

make fmt

if ! git diff --quiet; then
    echo ""
    echo "error: the following files were changed by formatter:"
    git diff --name-only | sed 's/^/  /'
    echo ""
    echo "Stage the changes and commit again."
    exit 1
fi

make lint
